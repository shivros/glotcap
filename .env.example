# Convex (client-side)
# Get this from your Convex dashboard after running `bunx convex dev`
VITE_CONVEX_URL=https://xxx.convex.cloud
# Optional: override Convex site URL for HTTP actions.
# VITE_CONVEX_SITE_URL=https://xxx.convex.site

# Convex Auth (set via `bunx convex env set` - NOT in .env)
# AUTH_GITHUB_ID=xxx
# AUTH_GITHUB_SECRET=xxx
# AUTH_GOOGLE_ID=xxx
# AUTH_GOOGLE_SECRET=xxx
# SITE_URL=https://yourapp.example.com
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# RESEND_FROM="GlotCap <onboarding@resend.dev>"
# RESEND_TEST_MODE=true

# Vercel Edge Config (for feature flags)
EDGE_CONFIG=

# OpenRouter (coach streaming)
# OPENROUTER_API_KEY=your_openrouter_key
# OPENROUTER_COACH_MODEL=mistralai/mistral-small-creative
# OPENROUTER_CORRECTIONS_MODEL=mistralai/mistral-small-creative
# SUMMARY_PROVIDER=openrouter
# SUMMARY_MODEL=openrouter/auto
# OPENROUTER_SITE_URL=https://yourapp.example.com
# OPENROUTER_APP_NAME=GlotCap
