{
  "name": "glotcap",
  "private": true,
  "packageManager": "bun@1.2.7",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bunx convex dev --once && concurrently -r npm:dev:web npm:dev:convex",
    "dev:web": "vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "bunx convex dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage:tts": "vitest run src/__tests__/tts-text-preprocessor.test.ts src/__tests__/speaking-session-coach-playback.test.tsx src/__tests__/speaking-session-coach-tts-port.test.ts convex/__tests__/tts.handlers.test.ts convex/__tests__/tts-stream.handlers.test.ts --coverage --coverage.include=shared/tts-text-preprocessor.ts --coverage.include=src/lib/speaking-session-coach-playback.ts --coverage.include=src/lib/speaking-session-coach-tts-port.ts --coverage.include=convex/tts.ts --coverage.include=convex/ttsStream.ts --coverage.thresholds.lines=90 --coverage.thresholds.statements=90 --coverage.thresholds.functions=90 --coverage.thresholds.branches=80",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "eslint . && tsc --noEmit",
    "format": "prettier",
    "format:check": "prettier --check \"**/*.{css,js,jsx,json,md,mdx,ts,tsx,yaml,yml}\" --cache",
    "format:write": "prettier --write \"**/*.{css,js,jsx,json,md,mdx,ts,tsx,yaml,yml}\" --cache",
    "secrets:check": "secretlint --maskSecrets --secretlintignore .secretlintignore",
    "quality:hooks": "bun run format:check && bun run lint && bun run typecheck",
    "quality": "echo '🔍 Running quality checks...' && echo '📋 Step 1/4: Formatting...' && bun run format:write && echo '✅ Formatting complete!' && echo '' && echo '📋 Step 2/4: Linting...' && bun run lint && echo '✅ Linting passed!' && echo '' && echo '📋 Step 3/4: Type checking...' && bun run typecheck && echo '✅ Type checking passed!' && echo '' && echo '📋 Step 4/4: Testing...' && bun run test --silent && echo '' && echo '✨ All quality checks passed!'",
    "quality:ci": "bun run format:check && bun run lint && bun run typecheck && bun run test --silent",
    "prepare": "./scripts/hooks/install-lefthook.sh"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@base-ui/react": "^1.0.0",
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/persistent-text-streaming": "^0.3.0",
    "@convex-dev/resend": "^0.2.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/genai": "^1.41.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.9.0",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.158.3",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "lucide-react": "^0.574.0",
    "neutral-cost": "^0.2.2",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^3.6.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "4.2.1",
    "ts-common": "workspace:*",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^6.0.5"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "@tanstack/devtools-vite": "^0.5.0",
    "@tanstack/eslint-config": "^0.3.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "~9.2.1",
    "eslint": "^9.39.2",
    "h3": "^2.0.1-rc.7",
    "happy-dom": "^20.0.0",
    "jsdom": "^28.0.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "secretlint": "^11.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  }
}
